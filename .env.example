# Copy to .env and fill in values
# Never commit .env to git

# Django
SECRET_KEY=replace-with-a-strong-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (PostgreSQL)
DB_NAME=twitter
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Celery broker and result backend (Redis db 3)
CELERY_BROKER_URL=redis://redis:6379/3
CELERY_RESULT_BACKEND=redis://redis:6379/3

# Cache backend: "memcached" (dev) or "redis" (prod)
USER_CACHE_BACKEND=memcached
MEMCACHED_LOCATION=memcached:11211
# Used when USER_CACHE_BACKEND=redis:
# USER_CACHE_REDIS_URL=redis://redis:6379/2

# AWS S3 (leave blank to use local FileSystemStorage)
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-west-1

# CORS (add Next.js URL in prod)
CORS_ALLOWED_ORIGINS=http://localhost:3000
